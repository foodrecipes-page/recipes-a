{
  "title": "Air-Fried Caraway Seed Wrap",
  "description": "A light and crispy snack that combines the subtle yet assertive flavor of caraway seeds with a touch of sweetness for a romantic twist.",
  "cuisine": "British",
  "diet": [
    "low-carb"
  ],
