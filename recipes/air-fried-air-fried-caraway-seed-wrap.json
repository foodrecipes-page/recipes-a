    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "Minced Garlic",
      "amount": "1 clove"
    },
    {
      "name": "All-Purpose Flour",
      "amount": "1/4 cup"
    },
    {
      "name": "Paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "Pinch"
    }
  ],
  "instructions": [
    "Preheat your air fryer to 375°F (190°C).",
    "In a small bowl, mix together olive oil, honey, minced garlic, caraway seeds, flour, paprika, and salt until well combined. The mixture should resemble sand.",
    "Place the mixture in an even layer inside your air fryer basket and spread it out evenly.",
    "Air fry for 8-10 minutes or until golden brown and crispy. Keep a close eye as caraway seeds can burn easily.",
    "Let cool slightly before serving."
  ],
