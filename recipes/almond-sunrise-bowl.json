      "amount": "2 tbsp"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "coconut milk",
      "amount": "1/2 cup"
    },
    {
      "name": "banana slices",
      "amount": "6"
    },
    {
      "name": "berries (strawberries, blueberries)",
      "amount": "3 tbsp per person"
    },
    {
      "name": "almond slivers or almonds",
      "amount": "handful"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "In a mixing bowl, combine almond flour, lime juice, and vanilla extract. Mix until smooth.",
    "Pour coconut milk over the mixture and stir well until fully combined.",
    "Transfer the mixture into an oven-safe dish or ramekin bowl and top with banana slices, berries (if using), and almond slivers on top.",
    "Bake for about 10-15 minutes or until golden brown and set. Avoid broiling as it can burn quickly at this temperature.",
    "Serve immediately while warm."
