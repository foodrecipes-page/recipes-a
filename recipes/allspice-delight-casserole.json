{
  "title": "Allspice Delight Casserole",
  "description": "A rich, flaky, nostalgic American dish featuring allspice berries, ideal for a vegetarian-friendly dinner option.",
  "cuisine": "American",
  "diet": [
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "All-Purpose Flour",
      "amount": "1 cup"
    },
    {
      "name": "Vegetable Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Baking Powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Water",
      "amount": "1 cup"
    },
    {
      "name": "Allspice Berries",
      "amount": "2 tablespoons, lightly crushed"
    },
    {
      "name": "Carrots",
      "amount": "3 medium, peeled and sliced"
    },
    {
      "name": "Onions",
      "amount": "1 large, finely chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C). In a mixing bowl, combine flour, vegetable oil, baking powder, and salt. Add water slowly while stirring until a dough forms.",
    "Fold in crushed allspice berries and finely chopped onions. Gently mix the carrot slices into the mixture.",
    "Transfer the mixture to a greased 8x8 inch baking dish. Bake for 25 minutes or until golden brown.",
    "Allow it to cool slightly before serving. Serve with a side of garlic bread for a complete meal."
  ],
